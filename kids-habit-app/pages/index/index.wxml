<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部用户信息 -->
  <view class="header card">
    <view class="user-info">
      <view class="avatar">
        <image wx:if="{{childProfile.avatarType === 'image'}}" class="avatar-image" src="{{childProfile.avatar}}" mode="aspectFill"></image>
        <text wx:else>{{childProfile.avatar}}</text>
      </view>
      <view class="nickname">{{childProfile.nickname}}</view>
    </view>
    <view class="points-info">
      <view class="points">⭐ {{points}} 积分</view>
      <view class="progress">{{todayCompleted}}/{{todayTotal}} 今日完成</view>
    </view>
    <view class="continuous-days">🔥 已连续 {{continuousDays}} 天</view>
  </view>

  <!-- 全部完成提示 -->
  <view class="all-complete card" wx:if="{{showAllComplete}}">
    <view class="complete-icon">🎉</view>
    <view class="complete-text">太棒了！今天的所有任务都完成啦！</view>
  </view>

  <!-- 周统计卡片 -->
  <view class="weekly-stats card">
    <view class="stats-header">
      <view class="stats-title">📊 本周统计</view>
      <view class="stats-week">{{weeklyStats.weekLabel}}</view>
    </view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{weeklyStats.totalCheckIns}}</view>
        <view class="stat-label">打卡次数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{weeklyStats.perfectDays}}</view>
        <view class="stat-label">完美天数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">🔥 {{continuousDays}}</view>
        <view class="stat-label">连续天数</view>
      </view>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="task-section">
    <view class="section-title">📋 今日任务</view>
    
    <view class="task-list">
      <view
        class="task-card card {{item.completedToday ? 'completed' : ''}} {{item.type === 'bad' ? 'bad-task' : 'good-task'}}"
        wx:for="{{tasks}}"
        wx:key="_id"
        data-id="{{item._id}}"
        data-index="{{index}}"
        bindtap="checkInTask"
      >
        <view class="task-icon">{{item.icon}}</view>
        <view class="task-info">
          <view class="task-name">{{item.name}}</view>
          <view class="task-points {{item.type === 'good' ? 'good-color' : 'bad-color'}}">
            {{item.type === 'good' ? '+' : '-'}}{{item.points}} 积分
          </view>
        </view>
        <view class="task-status">
          <view class="check-mark" wx:if="{{item.completedToday}}">✓</view>
          <view class="check-circle" wx:else></view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{tasks.length === 0}}">
      <view class="empty-icon">📝</view>
      <view class="empty-text">还没有任务哦</view>
      <view class="empty-hint">去设置页添加任务吧~</view>
    </view>
  </view>

  <!-- 庆祝动画 -->
  <view class="celebration {{showCelebration ? 'show' : ''}}" wx:if="{{showCelebration}}">
    <view class="celebration-content">
      <view class="celebration-icon">{{celebrationType === 'success' ? '🎉' : celebrationType === 'warning' ? '⭐' : '✨'}}</view>
      <view class="celebration-text {{celebrationType === 'warning' ? 'bad-color' : 'good-color'}}">{{celebrationText}}</view>
    </view>
  </view>

  <!-- 徽章解锁动画 -->
  <view class="badge-unlock {{showBadgeUnlock ? 'show' : ''}}" wx:if="{{showBadgeUnlock}}">
    <view class="badge-unlock-content">
      <view class="badge-unlock-icon">{{badgeUnlockData.icon}}</view>
      <view class="badge-unlock-title">🏆 成就解锁!</view>
      <view class="badge-unlock-text">{{badgeUnlockData.name}}</view>
    </view>
  </view>
</view>
