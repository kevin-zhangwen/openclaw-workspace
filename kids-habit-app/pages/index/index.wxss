/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部用户信息 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FF9500, #FFB347);
  color: white;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.nickname {
  font-size: 44rpx;
  font-weight: bold;
}

.points-info {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 10rpx;
}

.points {
  font-size: 36rpx;
  font-weight: bold;
}

.progress {
  font-size: 28rpx;
  opacity: 0.9;
}

.continuous-days {
  font-size: 32rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

/* 全部完成提示 */
.all-complete {
  background: linear-gradient(135deg, #FFD699, #FFE5CC);
  text-align: center;
  padding: 40rpx;
}

.complete-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.complete-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9500;
}

/* 任务区域 */
.task-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx;
  margin-bottom: 10rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
}

.task-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin: 16rpx 20rpx;
  transition: all 0.3s;
}

.task-card:active {
  transform: scale(0.98);
}

.task-card.completed {
  opacity: 0.7;
  background: #f5f5f5;
}

.task-card.good-task {
  border-left: 8rpx solid #52C41A;
}

.task-card.bad-task {
  border-left: 8rpx solid #FF4D4F;
}

.task-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.task-points {
  font-size: 28rpx;
  font-weight: bold;
}

.task-status {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
}

.check-mark {
  width: 50rpx;
  height: 50rpx;
  background: #52C41A;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.check-circle {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid #ddd;
  border-radius: 50%;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
}

/* 庆祝动画 */
.celebration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.celebration.show {
  opacity: 1;
  visibility: visible;
}

.celebration-content {
  text-align: center;
  animation: bounce 0.5s ease-in-out infinite;
}

.celebration-icon {
  font-size: 120rpx;
}

.celebration-text {
  font-size: 80rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 徽章解锁动画 */
.badge-unlock {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.badge-unlock.show {
  opacity: 1;
  visibility: visible;
}

.badge-unlock-content {
  text-align: center;
  animation: zoomIn 0.5s ease-out;
}

.badge-unlock-icon {
  font-size: 150rpx;
  animation: rotate 1s ease-in-out;
}

.badge-unlock-title {
  font-size: 48rpx;
  color: #FFD700;
  font-weight: bold;
  margin-top: 30rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.badge-unlock-text {
  font-size: 32rpx;
  color: #fff;
  margin-top: 16rpx;
  opacity: 0.9;
}

@keyframes zoomIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes rotate {
  0% { transform: rotate(-180deg) scale(0); }
  100% { transform: rotate(0deg) scale(1); }
}
