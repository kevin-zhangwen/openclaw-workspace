/* pages/settings/settings.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 个人信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 0;
  overflow: hidden;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.profile-avatar {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.profile-info {
  flex: 1;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.profile-points {
  font-size: 28rpx;
  opacity: 0.9;
}

.profile-arrow {
  font-size: 48rpx;
  opacity: 0.7;
}

.profile-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255,255,255,0.15);
}

.profile-stats .stat-item {
  text-align: center;
  flex: 1;
}

.profile-stats .stat-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.profile-stats .stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.profile-stats .stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 20rpx;
}

/* 家长验证入口 */
.parent-verify {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: linear-gradient(135deg, #FFB347, #FFD699);
  text-align: center;
}

.verify-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.verify-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.verify-hint {
  font-size: 26rpx;
  color: #666;
}

/* 家长管理区域 */
.parent-section {
  margin-top: 20rpx;
}

.section {
  margin-bottom: 20rpx;
}

/* 通用 section title（用于没有 header 的区域） */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.btn-add {
  background: linear-gradient(135deg, #FF9500, #FFB347);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255, 149, 0, 0.25);
}

.btn-add:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(255, 149, 0, 0.25);
}

/* 孩子档案编辑器 */
.profile-editor {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.avatar-selector {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.avatar-option {
  font-size: 48rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.avatar-option.selected {
  background: #FFB347;
  transform: scale(1.1);
}

.btn-save {
  background: linear-gradient(135deg, #FF9500, #FFB347);
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 列表项 */
.item-list {
  display: flex;
  flex-direction: column;
}

.item-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin: 0 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.item-card:first-child {
  border-top: 2rpx solid #f5f5f5;
}

.item-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.item-detail {
  font-size: 24rpx;
  color: #666;
}

.item-actions {
  display: flex;
  gap: 16rpx;
}

.btn-edit {
  color: #FF9500;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.btn-delete {
  color: #FF4D4F;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 28rpx;
  background: #fafafa;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 32rpx;
  color: #333;
}

.setting-action {
  font-size: 28rpx;
  color: #FF9500;
}

.setting-item.danger .setting-label {
  color: #FF4D4F;
}

.setting-action.danger-text {
  color: #FF4D4F;
}

/* 密码输入弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  width: 600rpx;
  text-align: center;
  animation: bounce 0.3s ease-in-out;
  position: relative;
  max-height: 80vh;
  overflow-y: auto;
}

.form-modal {
  width: 700rpx;
  text-align: left;
}

/* 个人信息详情弹窗 */
.profile-modal {
  width: 700rpx;
  text-align: left;
  padding: 0;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.profile-modal-header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  border-radius: 32rpx 32rpx 0 0;
}

.profile-modal-avatar {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.profile-modal-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.profile-modal-points {
  font-size: 28rpx;
  opacity: 0.9;
}

.profile-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  background: #f8f9fa;
}

.profile-stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.profile-stat-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.profile-stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 4rpx;
}

.profile-stat-label {
  font-size: 22rpx;
  color: #999;
}

.profile-section {
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.profile-section:last-child {
  border-bottom: none;
}

.profile-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.profile-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.profile-info-row:last-child {
  border-bottom: none;
}

.profile-info-label {
  font-size: 28rpx;
  color: #666;
}

.profile-info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.profile-badge-preview {
  padding: 30rpx;
}

.recent-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FFF9F0, #FFE5CC);
  border: 2rpx solid #FFB347;
  border-radius: 16rpx;
  padding: 20rpx;
  min-width: 120rpx;
}

.recent-badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.recent-badge-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.no-badges {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.no-badges-hint {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.7;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.password-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 40rpx;
  text-align: center;
  letter-spacing: 20rpx;
  margin-bottom: 20rpx;
}

.password-error {
  color: #FF4D4F;
  font-size: 26rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-buttons {
  display: flex;
  justify-content: space-around;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.btn-confirm {
  background: linear-gradient(135deg, #FF9500, #FFB347);
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.icon-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.icon-option {
  font-size: 40rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.icon-option.selected {
  background: #FFB347;
  transform: scale(1.1);
}

.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-option {
  flex: 1;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  transition: all 0.3s;
}

.radio-option.selected {
  background: #FFB347;
  color: white;
}

@keyframes bounce {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
