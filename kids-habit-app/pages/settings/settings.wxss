/* pages/settings/settings.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 通用卡片样式 */
.card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

/* 个人信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 0;
  overflow: hidden;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.profile-avatar {
  font-size: 80rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.profile-info {
  flex: 1;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.profile-points {
  font-size: 28rpx;
  opacity: 0.9;
}

.profile-arrow {
  font-size: 48rpx;
  opacity: 0.7;
}

.profile-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255,255,255,0.15);
}

.profile-stats .stat-item {
  text-align: center;
  flex: 1;
}

.profile-stats .stat-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.profile-stats .stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.profile-stats .stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 20rpx;
}

/* 通用 section */
.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 0 20rpx 0;
}

/* 家长验证入口 */
.parent-verify {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: linear-gradient(135deg, #FFB347, #FFD699);
  text-align: center;
}

.verify-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.verify-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.verify-hint {
  font-size: 26rpx;
  color: #666;
}

/* 孩子档案简化版 */
.child-profile-simple {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.child-avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.child-avatar-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 6rpx solid #FFB347;
}

.child-avatar-emoji {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9500, #FFB347);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: #667eea;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 4rpx solid white;
}

.child-nickname-wrapper {
  width: 100%;
  max-width: 400rpx;
  margin-bottom: 30rpx;
}

.nickname-label {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.nickname-input-simple {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.btn-save {
  background: linear-gradient(135deg, #FF9500, #FFB347);
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 个人信息详情弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  width: 700rpx;
  text-align: center;
  animation: bounce 0.3s ease-in-out;
  position: relative;
  max-height: 80vh;
  overflow-y: auto;
}

.profile-modal {
  width: 700rpx;
  text-align: left;
  padding: 0;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.profile-modal-header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  border-radius: 32rpx 32rpx 0 0;
}

.profile-modal-avatar {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-modal-avatar-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.profile-modal-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.profile-modal-points {
  font-size: 28rpx;
  opacity: 0.9;
}

.profile-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  background: #f8f9fa;
}

.profile-stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.profile-stat-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.profile-stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 4rpx;
}

.profile-stat-label {
  font-size: 22rpx;
  color: #999;
}

.profile-section {
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.profile-section:last-child {
  border-bottom: none;
}

.profile-section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.profile-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.profile-info-row:last-child {
  border-bottom: none;
}

.profile-info-label {
  font-size: 28rpx;
  color: #666;
}

.profile-info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.profile-badge-preview {
  padding: 30rpx;
}

.recent-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FFF9F0, #FFE5CC);
  border: 2rpx solid #FFB347;
  border-radius: 16rpx;
  padding: 20rpx;
  min-width: 120rpx;
}

.recent-badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.recent-badge-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.no-badges {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.no-badges-hint {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.7;
}

@keyframes bounce {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
