<!--pages/achievement/achievement.wxml-->
<view class="container">
  <view class="header card">
    <view class="header-title">🏆 我的成就</view>
    <view class="header-subtitle">收集所有徽章，成为习惯小达人！</view>
  </view>

  <view class="badge-grid">
    <view 
      class="badge-card card {{item.unlocked ? 'unlocked' : 'locked'}}"
      wx:for="{{badges}}"
      wx:key="*this"
      data-index="{{index}}"
      bindtap="viewBadgeDetail"
    >
      <view class="badge-icon">{{item.unlocked ? item.icon : '🔒'}}</view>
      <view class="badge-name">{{item.name}}</view>
      <view class="badge-status" wx:if="{{item.unlocked}}">
        <view class="unlock-date">已解锁</view>
      </view>
    </view>
  </view>

  <!-- 徽章详情弹窗 -->
  <view class="modal-overlay {{showBadgeDetail ? 'show' : ''}}" wx:if="{{showBadgeDetail}}" bindtap="closeBadgeDetail">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-badge-icon">{{selectedBadge.icon}}</view>
      <view class="modal-badge-name">{{selectedBadge.name}}</view>
      <view class="modal-badge-desc">{{selectedBadge.description}}</view>
      <view class="modal-badge-condition">
        <view class="condition-label">解锁条件：</view>
        <view class="condition-text">{{selectedBadge.condition}}</view>
      </view>
      <view class="modal-badge-status {{selectedBadge.unlocked ? 'unlocked' : 'locked'}}">
        {{selectedBadge.unlocked ? '🎉 已解锁' : '🔒 未解锁'}}
      </view>
      <view class="modal-close-btn" bindtap="closeBadgeDetail">关闭</view>
    </view>
  </view>
</view>
